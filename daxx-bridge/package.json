    "start": "tsx src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
